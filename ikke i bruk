const FC = D.fc;
const MILE = ['RØD SONE','GUL SONE','Mekanisk Ferdig'];
function isMile(a){ return MILE.includes(a.f); }
function hex(f){ return '#'+(FC[f]||'A9122B'); }
function parseISO(s){ if(!s) return null; const [y,m,d]=s.split('-').map(Number); return new Date(y,m-1,d); }
const TODAY=new Date(); TODAY.setHours(0,0,0,0);
function fmt(s){ if(!s) return ''; const [y,m,d]=s.split('-'); return d+'.'+m+'.'+y.slice(2); }
function isOngoing(a){ const s=parseISO(a.s),e=parseISO(a.e); if(isMile(a)) return false; return s&&e&&s<=TODAY&&e>=TODAY; }
function loc(a){ return [a.p,a.so].filter(Boolean).join(' · '); }
function dkey(s){ if(!s) return 99999999; const [y,m,d]=s.split('-'); return (+y)*10000+(+m)*100+(+d); }
function planNum(p){ const m=(p||'').match(/Plan (\d)/); return m?+m[1]:99; }
function soneNum(s){ const m=(s||'').match(/Sone (\d)/); return m?+m[1]:99; }

// STATE: 'now' special, or a Set of selected chip-keys (leverandør names, 'Komplettering', 'ALLE', or 'MILE:x')
let nowMode=true;
let sel=new Set();
let view='list';

const levRow=document.getElementById('levRow');
function chipKeys(){
  // order: ALLE, Komplettering, milestones, leverandører (excl Komplettering)
  const keys=['ALLE','Komplettering', ...MILE.map(m=>'MILE:'+m)];
  D.levs.forEach(l=>{ if(l!=='Komplettering') keys.push(l); });
  return keys;
}
function chipLabel(k){
  if(k==='ALLE') return 'Alle';
  if(k.startsWith('MILE:')) return k.slice(5);
  return k;
}
function chipColor(k){
  if(k.startsWith('MILE:')) return hex(k.slice(5));
  return null;
}
function buildChips(){
  levRow.innerHTML='';
  chipKeys().forEach(k=>{
    const b=document.createElement('button');
    const on=!nowMode && sel.has(k);
    b.className='chip'+(on?' on':'');
    b.textContent=chipLabel(k);
    const col=chipColor(k);
    if(col){ b.style.borderColor=col; if(on){b.style.background=col; b.style.color=(k==='MILE:GUL SONE'?'#1c1a18':'#fff');} }
    b.onclick=()=>{
      nowMode=false;
      if(k==='ALLE'){ // ALLE is exclusive: selecting it clears others
        if(sel.has('ALLE')) sel.delete('ALLE'); else { sel.clear(); sel.add('ALLE'); }
      } else {
        sel.delete('ALLE');
        if(sel.has(k)) sel.delete(k); else sel.add(k);
      }
      if(sel.size===0) nowMode=true; // nothing selected -> back to now
      render();
    };
    levRow.appendChild(b);
  });
}
function matchKey(a,k){
  if(k==='ALLE') return true;
  if(k==='Komplettering') return a.l==='Komplettering';
  if(k.startsWith('MILE:')) return a.f===k.slice(5);
  return a.l===k;
}
function selected(){
  if(nowMode) return D.acts.filter(isOngoing);
  if(sel.has('ALLE')) return D.acts.slice();
  return D.acts.filter(a=>{ for(const k of sel){ if(matchKey(a,k)) return true; } return false; });
}
function weekList(){
  let min=null,max=null;
  D.acts.forEach(a=>{const s=parseISO(a.s),e=parseISO(a.e); if(s&&(!min||s<min))min=s; if(e&&(!max||e>max))max=e;});
  const mon=new Date(min); mon.setDate(mon.getDate()-((mon.getDay()+6)%7));
  const weeks=[]; let c=new Date(mon);
  while(c<=max){weeks.push(new Date(c)); c.setDate(c.getDate()+7);}
  return weeks;
}
function isoWeek(d){const t=new Date(d);t.setHours(0,0,0,0);t.setDate(t.getDate()+3-((t.getDay()+6)%7));const w1=new Date(t.getFullYear(),0,4);return 1+Math.round(((t-w1)/86400000-3+((w1.getDay()+6)%7))/7);}

// Sort rows GROUP-WISE (B): each Plan/Sone-blokk holdes samlet, og gruppene ordnes etter sin
// TIDLIGSTE aktivitet. Inne i en gruppe sorteres aktivitetene kronologisk. Slik havner etasjen/
// sonen som starter først øverst, samtidig som Plan/Sone-inndelingen bevares.
function sortRows(rows){
  // Grupper på den visuelle gruppenøkkelen (grp): "Plan X · Sone Y", evt. bare planen for milepæler.
  const groups=new Map();
  rows.forEach(a=>{ const k=grp(a); if(!groups.has(k)) groups.set(k,[]); groups.get(k).push(a); });
  const list=[];
  groups.forEach(items=>{
    // tidligste oppstart i gruppen
    let min=Infinity; items.forEach(a=>{ const k=dkey(a.s); if(k<min) min=k; });
    // kronologisk rekkefølge inne i gruppen (start, så slutt, så plan/sone, så navn)
    items.sort((a,b)=>
      (dkey(a.s)-dkey(b.s)) || (dkey(a.e)-dkey(b.e)) ||
      (planNum(a.p)-planNum(b.p)) || (soneNum(a.so)-soneNum(b.so)) ||
      String(a.w||'').localeCompare(String(b.w||''),'no'));
    list.push({min, pa:planNum(items[0].p), sa:soneNum(items[0].so), items});
  });
  // ordne gruppene etter tidligste aktivitet; lik dato brytes på plan, så sone (stabilt)
  list.sort((g1,g2)=> (g1.min-g2.min) || (g1.pa-g2.pa) || (g1.sa-g2.sa));
  const out=[]; list.forEach(g=>g.items.forEach(a=>out.push(a))); return out;
}
function grp(a){
  // milestones: show only Plan (sone blanked in data). 
  if(isMile(a)) return a.p||'—';
  return [a.p||'',a.so||''].filter(Boolean).join(' · ') || '—';
}

function renderList(rows){
  const main=document.getElementById('main');
  if(!rows.length){main.innerHTML='<div class="empty">Ingen arbeider å vise.</div>';return;}
  rows=sortRows(rows);
  let html=''; let lastG=null;
  rows.forEach(a=>{
    const g=grp(a);
    if(g!==lastG){ html+=`<div class="glabel">${g}</div>`; lastG=g; }
    if(isMile(a)){
      html+=`<div class="card"><div class="bar" style="background:${hex(a.f)}"></div>
        <div class="body"><div class="w">${a.w}<span class="mile-badge" style="background:${hex(a.f)}">MILEPÆL</span></div>
        <div class="meta"><span class="tag" style="background:${hex(a.f)};color:#fff">${a.f}</span></div>
        <div class="dates">${fmt(a.s)}</div></div></div>`;
    } else {
      const live=isOngoing(a)?'<span class="live">PÅGÅR</span>':'';
      html+=`<div class="card"><div class="bar" style="background:${hex(a.f)}"></div>
        <div class="body"><div class="w">${a.w||a.l}${live}</div>
        <div class="meta"><span class="tag" style="background:${hex(a.f)}">${a.f}</span><b>${a.l}</b></div>
        <div class="dates">${fmt(a.s)} → ${fmt(a.e)} <span style="color:var(--muted);font-weight:600">(${a.d})</span></div></div></div>`;
    }
  });
  main.innerHTML=html;
}
function renderTime(rows){
  const main=document.getElementById('main');
  if(!rows.length){main.innerHTML='<div class="empty">Ingen arbeider å vise.</div>';return;}
  rows=sortRows(rows);
  const weeks=weekList(); const W=34; const dayMs=86400000; const first=weeks[0];
  function xFor(d){return ((d-first)/dayMs/7)*W;}
  const totalW=weeks.length*W;
  const todayX=xFor(TODAY);
  const curWk=isoWeek(TODAY), curYr=TODAY.getFullYear();

  // count how many selected rows are active each week (for the week-status line)
  function activeInWeek(wkStart){
    const wkEnd=new Date(wkStart); wkEnd.setDate(wkEnd.getDate()+6);
    let n=0;
    rows.forEach(a=>{ if(isMile(a)) return; const s=parseISO(a.s),e=parseISO(a.e); if(s&&e&&s<=wkEnd&&e>=wkStart) n++; });
    return n;
  }

  let leftHtml='', trackHtml='', lastG=null;
  rows.forEach(a=>{
    const g=grp(a);
    if(g!==lastG){
      leftHtml+=`<div class="tl2-lgroup">${g}</div>`;
      trackHtml+=`<div class="tl2-tgroup"></div>`;
      lastG=g;
    }
    const s=parseISO(a.s),e=parseISO(a.e);
    const dts=isMile(a)?fmt(a.s):((a.s||a.e)?`${fmt(a.s)} → ${fmt(a.e)}`:'');
    const tagColor=isMile(a)?`${hex(a.f)};color:#fff`:hex(a.f);
    const whoLine=isMile(a)?(a.p||''):a.l;
    leftHtml+=`<div class="tl2-lrow">
      <div class="work">${a.w||a.l}</div>
      <div><span class="tag" style="background:${tagColor}">${a.f}</span></div>
      <div class="who">${whoLine}</div>
      <div class="dts">${dts}</div></div>`;
    let mark='';
    if(isMile(a)){ if(s){mark=`<div class="tl2-mile" style="left:${xFor(s)}px;background:${hex(a.f)}"></div>`;} }
    else if(s&&e){ const left=xFor(s); const w=Math.max(W*0.5,((e-s)/dayMs/7)*W+W*0.5);
      mark=`<div class="tl2-bar" style="left:${left}px;width:${w}px;background:${hex(a.f)}"></div>`; }
    const cells=weeks.map(w=>{const cur=(isoWeek(w)===curWk&&w.getFullYear()===curYr);return `<div class="tl2-cell${cur?' cur':''}"></div>`;}).join('');
    trackHtml+=`<div class="tl2-trow" style="width:${totalW}px">${cells}${mark}</div>`;
  });

  const wkCountRow=weeks.map(w=>{
    const cur=(isoWeek(w)===curWk&&w.getFullYear()===curYr);
    const n=activeInWeek(w);
    return `<div class="tl2-wkcount${cur?' cur':''}">${n||''}</div>`;
  }).join('');
  const wkHead=weeks.map(w=>{
    const cur=(isoWeek(w)===curWk&&w.getFullYear()===curYr);
    return `<div class="tl2-wk${cur?' cur':''}">u${String(isoWeek(w)).padStart(2,'0')}<span>${('0'+w.getDate()).slice(-2)}.${('0'+(w.getMonth()+1)).slice(-2)}</span></div>`;
  }).join('');

  main.innerHTML=`<div class="tl2">
    <div class="tl2-left">
      <div class="tl2-lhead">Arbeid</div>
      <div id="tl2Left">${leftHtml}</div>
    </div>
    <div class="tl2-right" id="tl2Right">
      <div class="tl2-rhead">
        <div class="tl2-wkstatus" style="width:${totalW}px">${wkCountRow}</div>
        <div class="tl2-weeks" style="width:${totalW}px">${wkHead}</div>
      </div>
      <div class="tl2-track" style="width:${totalW}px">
        ${trackHtml}
        <div class="tl2-today" style="left:${todayX}px"></div>
      </div>
    </div>
  </div>`;

  const right=document.getElementById('tl2Right');
  if(right){ const target=Math.max(0, todayX - right.clientWidth*0.42); right.scrollLeft=target; }
}
function render(){
  buildChips();
  document.getElementById('nowBtn').classList.toggle('on',nowMode);
  document.getElementById('vList').classList.toggle('on',view==='list');
  document.getElementById('vTime').classList.toggle('on',view==='time');
  const rows=selected();
  let label;
  if(nowMode) label=rows.length+' pågående nå';
  else {
    const names=[...sel].map(chipLabel);
    label=rows.length+' arbeider'+(names.length?' · '+names.join(', '):'');
  }
  document.getElementById('count').textContent=label;
  document.getElementById('hint').style.display = nowMode? 'none':'block';
  if(view==='list') renderList(rows); else renderTime(rows);
}
document.getElementById('nowBtn').onclick=()=>{nowMode=true; sel.clear(); render();};
document.getElementById('vList').onclick=()=>{view='list';render();};
document.getElementById('vTime').onclick=()=>{view='time';render();};
render();
</script>
</body>

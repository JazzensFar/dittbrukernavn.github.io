<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#A9122B">
<title>FB1-B Fremdrift</title>
<style>
:root{--red:#A9122B;--ink:#231F20;--bronze:#A37D50;--cream:#FBF8F3;--line:#E7E1D8;--white:#fff;--muted:#7a736b;}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{margin:0;padding:0;background:var(--cream);color:var(--ink);
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;-webkit-text-size-adjust:100%;}
.safe{padding:env(safe-area-inset-top) env(safe-area-inset-right) 0 env(safe-area-inset-left);}
header{background:var(--red);color:#fff;padding:14px 16px 12px;position:sticky;top:0;z-index:50;box-shadow:0 2px 10px rgba(0,0,0,.15);}
.htop{display:flex;align-items:center;gap:12px;}
.htop img{height:34px;width:auto;}
.htop .ttl{font-weight:800;font-size:17px;letter-spacing:.3px;line-height:1.1;}
.htop .sub{font-size:11px;opacity:.9;margin-top:2px;}
.sig{font-size:10px;color:#F0D9A8;font-weight:700;margin-top:6px;letter-spacing:.3px;}
.controls{padding:12px 12px 0;}
.seg{display:flex;background:#efe7da;border-radius:14px;padding:4px;gap:4px;margin-bottom:10px;}
.seg button{flex:1;border:0;background:transparent;padding:11px 8px;font-size:15px;font-weight:700;color:var(--ink);border-radius:11px;transition:.15s;}
.seg button.on{background:var(--red);color:#fff;box-shadow:0 1px 4px rgba(0,0,0,.2);}
.now-btn{width:100%;border:0;border-radius:14px;padding:15px;font-size:17px;font-weight:800;background:var(--ink);color:#fff;margin-bottom:10px;display:flex;align-items:center;justify-content:center;gap:8px;}
.now-btn.on{background:var(--red);}
.now-btn .dot{width:9px;height:9px;border-radius:50%;background:#7CFC9B;box-shadow:0 0 8px #7CFC9B;}
.lev-row{display:flex;gap:8px;overflow-x:auto;padding:2px 0 8px;-webkit-overflow-scrolling:touch;}
.lev-row::-webkit-scrollbar{display:none;}
.chip{flex:0 0 auto;border:1.5px solid var(--line);background:#fff;border-radius:20px;padding:9px 15px;font-size:14px;font-weight:600;color:var(--ink);white-space:nowrap;}
.chip.on{background:var(--bronze);border-color:var(--bronze);color:#fff;}
.hint{font-size:11px;color:var(--muted);padding:0 14px 6px;}
.count{font-size:13px;color:var(--muted);padding:0 14px 8px;font-weight:600;}
main{padding:0 12px 40px;}
/* LIST cards */
.glabel{font-weight:800;font-size:12.5px;color:#fff;background:var(--bronze);border-radius:9px;padding:7px 12px;margin:14px 0 8px;letter-spacing:.3px;}
.glabel:first-child{margin-top:2px;}
.card{background:#fff;border-radius:14px;margin-bottom:10px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.08);display:flex;}
.card .bar{width:8px;flex:0 0 8px;}
.card .body{padding:12px 14px;flex:1;min-width:0;}
.card .w{font-size:15.5px;font-weight:700;line-height:1.25;margin-bottom:5px;}
.card .meta{font-size:12.5px;color:var(--muted);display:flex;flex-wrap:wrap;gap:4px 10px;align-items:center;}
.card .meta b{color:var(--ink);font-weight:600;}
.loc{display:inline-block;font-size:11px;font-weight:700;background:var(--ink);color:#fff;padding:2px 8px;border-radius:6px;}
.tag{display:inline-block;font-size:11px;font-weight:700;padding:2px 8px;border-radius:6px;color:#1c1a18;}
.dates{font-size:12.5px;font-weight:700;color:var(--ink);margin-top:6px;}
.live{display:inline-block;font-size:10px;font-weight:800;color:#fff;background:var(--red);padding:2px 7px;border-radius:5px;margin-left:6px;vertical-align:middle;}
.mile-badge{display:inline-block;font-size:10px;font-weight:800;padding:2px 7px;border-radius:5px;margin-left:6px;vertical-align:middle;color:#fff;}
/* TIMELINE - frozen left panel + scrollable right */
.tl2{display:flex; background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 1px 3px rgba(0,0,0,.08);}
.tl2-left{flex:0 0 168px; z-index:2; background:#fff; box-shadow:3px 0 8px rgba(0,0,0,.12);}
.tl2-right{flex:1; overflow-x:auto; -webkit-overflow-scrolling:touch;}
.tl2-right::-webkit-scrollbar{height:8px;}
.tl2-right::-webkit-scrollbar-thumb{background:#cfc6ba; border-radius:4px;}
/* header: two stacked header rows (week-status line + column header) */
.tl2-lhead{height:64px; box-sizing:border-box; background:var(--ink); color:#fff; font-size:11.5px; font-weight:700; display:flex; align-items:flex-end; padding:0 10px 8px; position:sticky; top:0; z-index:3;}
.tl2-rhead{position:sticky; top:0; z-index:1;}
.tl2-wkstatus{display:flex; height:26px; background:#3a2e2a;}
.tl2-wkcount{flex:0 0 34px; box-sizing:border-box; text-align:center; color:#F0D9A8; font-size:9px; font-weight:800; border-left:1px solid #4a3d38; display:flex; align-items:center; justify-content:center;}
.tl2-wkcount.cur{background:var(--red); color:#fff;}
.tl2-weeks{display:flex; height:38px; box-sizing:border-box; background:var(--ink);}
.tl2-wk{flex:0 0 34px; height:38px; box-sizing:border-box; text-align:center; color:#fff; font-size:9.5px; line-height:1.15; border-left:1px solid #3a3633; display:flex; flex-direction:column; align-items:center; justify-content:center;}
.tl2-wk.cur{background:#5a1020;}
/* body rows */
.tl2-lrow{height:82px; box-sizing:border-box; padding:8px 10px; border-bottom:1px solid var(--line); display:flex; flex-direction:column; justify-content:flex-start; gap:1px; overflow:hidden;}
.tl2-lrow:nth-child(even){background:var(--cream);}
.tl2-lrow .work{font-weight:700; font-size:10.5px; line-height:1.25; margin:0 0 2px; color:var(--ink); display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;}
.tl2-lrow .tag{display:inline-block; font-size:9px; font-weight:800; padding:1px 6px; border-radius:5px; color:#1c1a18; margin-bottom:2px;}
.tl2-lrow .who{font-size:9.5px; color:var(--ink); font-weight:600;}
.tl2-lrow .dts{font-size:9.5px; font-weight:700; color:var(--ink); margin-top:1px;}
.tl2-track{position:relative;}
.tl2-trow{height:82px; box-sizing:border-box; border-bottom:1px solid var(--line); position:relative; display:flex;}
.tl2-trow:nth-child(even){background:var(--cream);}
.tl2-cell{flex:0 0 34px; border-left:1px solid #f0ece5;}
.tl2-cell.cur{background:rgba(169,18,43,.05);}
.tl2-bar{position:absolute; height:16px; top:50%; transform:translateY(-50%); border-radius:4px; box-shadow:0 1px 2px rgba(0,0,0,.2);}
.tl2-mile{position:absolute; top:50%; transform:translate(-50%,-50%) rotate(45deg); width:13px; height:13px; border:2px solid #fff; box-shadow:0 1px 3px rgba(0,0,0,.4);}
.tl2-today{position:absolute; top:0; bottom:0; width:3px; background:rgba(169,18,43,.16); border-left:2px solid var(--red); pointer-events:none;}
.tl2-lgroup{height:28px; box-sizing:border-box; background:var(--bronze); color:#fff; font-weight:800; font-size:11px; padding:0 10px; border-bottom:1px solid var(--line); letter-spacing:.3px; display:flex; align-items:center;}
.tl2-tgroup{height:28px; box-sizing:border-box; background:var(--bronze); border-bottom:1px solid var(--line); opacity:.18;}
.empty{text-align:center;color:var(--muted);padding:40px 20px;font-size:15px;}
.foot{text-align:center;font-size:10px;color:var(--bronze);font-weight:700;padding:16px;}
</style>
</head>
